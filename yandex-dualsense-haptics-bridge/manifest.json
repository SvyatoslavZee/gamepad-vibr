{
  "manifest_version": 3,
  "name": "DualSense Haptics Bridge",
  "version": "0.1.1",
  "description": "Routes browser gamepad vibration calls to DualSense over WebHID.",
  "content_scripts": [
    {
      "matches": [
        "https://*.yandex.ru/*",
        "https://plusgaming.yandex.ru/*",
        "https://igromir.yandex.ru/*",
        "http://localhost:8765/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "bridge.js"
      ],
      "matches": [
        "https://*.yandex.ru/*",
        "https://plusgaming.yandex.ru/*",
        "https://igromir.yandex.ru/*",
        "http://localhost:8765/*"
      ]
    }
  ]
}
